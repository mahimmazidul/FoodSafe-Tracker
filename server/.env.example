# FoodSafe Tracker — API server environment
# Copy to .env (or export in your shell) before running in production.

# Port the API listens on (frontend's VITE_API_URL defaults to :3001)
PORT=3001

# REQUIRED in production — secret used to sign JWTs
JWT_SECRET=change-me-to-a-long-random-string

# Token lifetime (jsonwebtoken format: 12h, 7d, ...)
JWT_EXPIRES_IN=12h

# SQLite database location
DB_PATH=./data/foodsafe.db

# Comma-separated list of allowed origins, or * for any
CORS_ORIGIN=http://localhost:5173

# Seed demo data on first start (set to false in production)
SEED_ON_START=true
