# FoodSafe Tracker Environment Variables
# Copy this file to .env.local and fill in the values

# Application
VITE_APP_NAME=FoodSafe Tracker
VITE_APP_VERSION=1.0.0

# API Configuration
# The frontend auto-detects the backend at this URL on startup.
# If reachable -> remote mode (REST API + JWT auth).
# If unreachable -> automatic fallback to offline demo mode (IndexedDB).
VITE_API_URL=http://localhost:3001/api
VITE_API_TIMEOUT=30000

# Feature Flags
# Set to true to FORCE offline demo mode even when the backend is running.
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_OFFLINE_MODE=true

# Analytics (optional)
# VITE_ANALYTICS_ID=UA-XXXXXXXX-X

# Sentry Error Tracking (optional)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
